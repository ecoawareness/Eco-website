# Server-side configuration for the Vercel deployment.
# Copy these into your Vercel project's Environment Variables.
# NEVER commit a real .env file — only this example belongs in git.

# Email of the single admin user. Must match a real Supabase auth account.
# REQUIRED: the /api/admin/* endpoints fail closed (500) if this is unset,
# so admin access can never fall back to a guessable default.
ADMIN_EMAIL=you@example.com

# Supabase service-role key (full database access). Server-only —
# it must never be shipped to the browser. The public site uses the
# anon key instead, which is safe to expose because Row-Level Security
# (see supabase/schema.sql) governs what it can read/write.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# EcoBot chat providers. At least one is required for /api/chat to work.
GROQ_API_KEY=your_groq_api_key
OPENROUTER_API_KEY=your_openrouter_api_key
